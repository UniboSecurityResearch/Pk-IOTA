ip link set mtu 9000 eth0
ip link set mtu 9000 eth1

p4c opcua_extraction.p4 || exit 1
simple_switch -i 1@eth0 -i 2@eth1 --log-console opcua_extraction.json &

while ! pgrep -x simple_switch >/dev/null; do sleep 1; done
until simple_switch_CLI <<< "help"; do sleep 1; done

simple_switch_CLI < commands.txt

tcpdump -i eth0 -w s1_ingress.pcap &
tcpdump -i eth1 -w s1_egress.pcap &
