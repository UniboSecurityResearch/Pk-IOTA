#!/bin/sh
set -eu

. /shared/common_service.sh
ensure_iproute

setup_iface eth0 10.10.20.13/24
setup_iface eth1 10.10.30.11/24

add_static_neigh eth0 10.10.20.11 02:00:00:10:02:01
add_static_neigh eth0 10.10.20.12 02:00:00:10:02:02
add_static_neigh eth1 10.10.30.12 02:00:00:10:03:02
add_static_neigh eth1 10.10.30.13 02:00:00:10:03:03

# Kathara does not run the image CMD: launch the OPC UA client explicitly.
# Basic256Sha256/SignAndEncrypt puts certificates on the wire (OPN messages),
# which is what the extraction P4 variant parses.
cat > /start_app.sh <<'EOS'
#!/bin/sh
export OPCUA_SECURITY_POLICY=Basic256Sha256
export OPCUA_SECURITY_MODE=SignAndEncrypt
exec python3 /app/app.py --lss=opc.tcp://10.10.30.12:4840 --vs=opc.tcp://10.10.30.13:4840 --ps=opc.tcp://10.10.20.11:4840
EOS
chmod +x /start_app.sh
nohup /start_app.sh > /shared/plc_logic.log 2>&1 &
