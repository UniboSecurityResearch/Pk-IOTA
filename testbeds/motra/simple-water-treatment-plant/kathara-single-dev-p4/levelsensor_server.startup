#!/bin/sh
set -eu

. /shared/common_service.sh
ensure_iproute

setup_iface eth0 10.10.30.12/24
setup_iface eth1 10.10.40.11/24

add_static_neigh eth0 10.10.30.11 02:00:00:10:03:01
add_static_neigh eth0 10.10.30.13 02:00:00:10:03:03
add_static_neigh eth1 10.10.40.12 02:00:00:10:04:02

# Kathara does not run the image CMD: launch the OPC UA server explicitly.
# /start_app.sh is re-invoked by the campaign runner to force fresh
# OpenSecureChannel handshakes inside the capture window.
cat > /start_app.sh <<'EOS'
#!/bin/sh
export OPCUA_SERVER_CERT=/pki/server-cert.pem
export OPCUA_SERVER_KEY=/pki/server-key.pem
cd /usr/src/app
exec "${POETRY_HOME:-/opt/poetry}/bin/poetry" run python server.py
EOS
chmod +x /start_app.sh
nohup /start_app.sh > /shared/levelsensor_server.log 2>&1 &
