#!/bin/sh
set -eu

. /shared/common_service.sh
ensure_iproute

setup_iface eth0 10.11.0.21/16
populate_otsec_hosts
add_static_neigh eth0 10.11.0.11 02:11:00:00:00:11
add_static_neigh eth0 10.11.0.12 02:11:00:00:00:12
add_static_neigh eth0 10.11.0.13 02:11:00:00:00:13
add_static_neigh eth0 10.11.0.14 02:11:00:00:00:14
add_static_neigh eth0 10.11.0.20 02:11:00:00:00:20
add_static_neigh eth0 10.11.0.22 02:11:00:00:00:22
add_static_neigh eth0 10.11.0.23 02:11:00:00:00:23
add_static_neigh eth0 10.11.0.24 02:11:00:00:00:24

# Kathara volume mounts require host directories; import the original config file from mounted dir.
if [ -f /workdir/OpenPLC_v3/host_plc/config.ini ]; then
  cp /workdir/OpenPLC_v3/host_plc/config.ini /workdir/OpenPLC_v3/etc/config.ini
fi
