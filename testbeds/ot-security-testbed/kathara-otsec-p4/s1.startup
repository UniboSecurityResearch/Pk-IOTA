p4c active.p4
simple_switch \
  -i 1@eth0 -i 2@eth1 -i 3@eth2 -i 4@eth3 -i 5@eth4 \
  -i 6@eth5 -i 7@eth6 -i 8@eth7 -i 9@eth8 \
  --log-console active.json > /shared/s1.log 2>&1 &

while ! pgrep simple_switch >/dev/null; do sleep 1; done
until simple_switch_CLI <<< "help"; do sleep 1; done
simple_switch_CLI <<< "$(cat commands.txt)"
